# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hotel_transylvania"

# NextAuth. Generate a secret with: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# Public site URL, used in emails, sitemap and structured data
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Stripe. Use test keys until go-live.
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# From `stripe listen` locally, or the webhook endpoint settings in the Stripe dashboard
STRIPE_WEBHOOK_SECRET="whsec_..."

# Resend for transactional email. Leave empty in development to log emails to the console instead.
RESEND_API_KEY=""
EMAIL_FROM="Hotel Transylvania <reservations@hoteltransylvania.ro>"
